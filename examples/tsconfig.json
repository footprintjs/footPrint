{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "footprintjs": ["../src/index.ts"],
      "footprintjs/trace": ["../src/trace.ts"],
      "footprintjs/advanced": ["../src/advanced.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["integrations/**"]
}
