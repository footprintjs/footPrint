{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts", "src/recorders.ts", "src/advanced.ts"],
  "entryPointStrategy": "resolve",
  "out": "api-docs",
  "name": "footprintjs",
  "readme": "README.md",
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "includeVersion": true,
  "categorizeByGroup": false,
  "searchInComments": true,
  "hideGenerator": true,
  "suppressCommentWarningsInDeclarationFiles": true,
  "categoryOrder": [
    "Quick Start",
    "Decision Branching",
    "Run",
    "Observe: Data",
    "Observe: Flow",
    "Self-Describing",
    "Snapshot & Composition",
    "Contract & Validation",
    "Error Utilities",
    "Dev Tools",
    "*"
  ],
  "navigationLinks": {
    "GitHub": "https://github.com/footprintjs/footPrint",
    "npm": "https://www.npmjs.com/package/footprintjs",
    "Playground": "https://footprintjs.github.io/footprint-playground/"
  }
}
