---
interface Props {
  code: string;
}
const { code } = Astro.props;
const uid = `mermaid-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="mermaid-wrap" data-uid={uid} data-code={code}>
  <div id={uid} class="mermaid-output"></div>
</div>

<script is:inline>
(function () {
  // Starlight sets data-theme="light" or data-theme="dark" on <html>.
  function getMermaidTheme() {
    return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'default';
  }

  var mermaidModule = null;

  function renderAll() {
    if (!mermaidModule) return;
    var theme = getMermaidTheme();
    mermaidModule.initialize({ startOnLoad: false, theme: theme, fontFamily: 'inherit' });

    var wraps = document.querySelectorAll('.mermaid-wrap');
    for (var w of wraps) {
      var uid = w.dataset.uid;
      var code = w.dataset.code;
      var out = document.getElementById(uid);
      if (!out || !code) continue;
      // Clear previous render before re-rendering on theme change
      out.textContent = '';
      (function (el, c, id) {
        // SVG from mermaid.render() is developer-authored content, not user input.
        // DOMParser parses it as XML for safe DOM insertion.
        mermaidModule.render(id + '-svg', c).then(function (r) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(r.svg, 'image/svg+xml');
          el.appendChild(doc.documentElement.cloneNode(true));
        }).catch(console.error);
      })(out, code, uid);
    }
  }

  function init() {
    if (!document.querySelector('.mermaid-wrap')) return;

    var script = document.createElement('script');
    script.type = 'module';
    script.textContent =
      'import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";' +
      'window.__mermaidLoaded(mermaid);';
    window.__mermaidLoaded = function (m) {
      mermaidModule = m;
      renderAll();

      // Re-render when Starlight toggles light/dark (watches data-theme attribute)
      var observer = new MutationObserver(function (mutations) {
        for (var mut of mutations) {
          if (mut.attributeName === 'data-theme') {
            renderAll();
            break;
          }
        }
      });
      observer.observe(document.documentElement, { attributes: true });
    };
    document.head.appendChild(script);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

<style>
  .mermaid-wrap {
    margin: 1.5rem 0;
    text-align: center;
  }
  .mermaid-output {
    min-height: 120px;
  }
  .mermaid-output svg {
    max-width: 100%;
    height: auto;
  }
</style>
