{
  "name": "footprintjs",
  "version": "0.1.0",
  "description": "Turn your whiteboard flowchart into running code — with automatic causal traces for LLM reasoning",
  "license": "MIT",
  "author": "Sanjay Krishna Anbalagan",
  "repository": {
    "type": "git",
    "url": "https://github.com/footprintjs/footPrint.git"
  },
  "homepage": "https://github.com/footprintjs/footPrint",
  "bugs": {
    "url": "https://github.com/footprintjs/footPrint/issues"
  },
  "keywords": [
    "footprint",
    "flowchart",
    "pipeline",
    "workflow",
    "llm",
    "causal-trace",
    "narrative",
    "state-management",
    "observability",
    "time-travel-debugging",
    "scope",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf build/* coverage dist node_modules package-lock.json",
    "build": "tsc && tsc -p tsconfig.esm.json",
    "prepare": "husky",
    "watch": "tsc -w",
    "test": "jest --coverage",
    "test:watch": "jest --passWithNoTests --watchAll --coverage=false",
    "release": "concurrently \"npm run format\" \"npm run lint\" \"npm run test\" \"npm run build\"",
    "release:lite": "npm run build",
    "lint": "eslint '{src,test}/**/*.ts' --ext .ts",
    "lint:fix": "eslint '{src,test}/**/*.ts' --ext .ts --fix",
    "format:fix": "prettier --config .prettierrc.js --write '{src,test}/**/*.ts'",
    "format": "prettier --config .prettierrc.js --list-different '{src,test}/**/*.ts'",
    "bench": "npx tsx bench/run.ts"
  },
  "jest": {
    "testMatch": [
      "**/**.test.ts"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "isolatedModules": true,
          "diagnostics": {
            "warnOnly": true
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|ts|tsx|json)$",
      "package.json"
    ],
    "coverageReporters": [
      "cobertura",
      "text",
      "text-summary"
    ],
    "coverageDirectory": "<rootDir>/build/coverage/",
    "coverageThreshold": {
      "global": {
        "statements": 95,
        "branches": 85,
        "functions": 98,
        "lines": 98
      }
    }
  },
  "files": [
    "dist/**/*",
    "!dist/test",
    "!dist/types/test",
    "!dist/esm/types/test"
  ],
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    },
    "./advanced": {
      "types": "./dist/types/advanced.d.ts",
      "import": "./dist/esm/advanced.js",
      "require": "./dist/advanced.js"
    }
  },
  "lint-staged": {
    "{src,test}/**/*.ts": [
      "eslint --fix",
      "prettier --config .prettierrc.js --write"
    ]
  },
  "sideEffects": false,
  "dependencies": {
    "lodash.get": "^4.4.2",
    "lodash.has": "^4.5.2",
    "lodash.mergewith": "^4.6.2",
    "lodash.set": "^4.3.2"
  },
  "peerDependencies": {
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "@types/lodash.get": "^4.4.9",
    "@types/lodash.has": "^4.5.9",
    "@types/lodash.mergewith": "^4.6.9",
    "@types/lodash.set": "^4.3.9",
    "@typescript-eslint/eslint-plugin": "^5.61.0",
    "@typescript-eslint/parser": "^5.61.0",
    "concurrently": "^8.0.1",
    "eslint": "^8.44.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-import-resolver-typescript": "^3.5.2",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-simple-import-sort": "^8.0.0",
    "fast-check": "^4.4.0",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "lint-staged": "^16.3.2",
    "prettier": "^2.8.1",
    "ts-jest": "^29.1.0",
    "typescript": "~5.4.5"
  }
}
